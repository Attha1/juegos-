!DOCTYPE html>                                                               
  <html lang="en">                                                              
  <head>          
    <meta charset="UTF-8">                                                      
    <title>HEART1</title>
    <link rel="stylesheet" href="./style.css">
  </head>
  <body>
  <canvas id="heart"></canvas>
    <script src="./script.js"></script>
  </body>
  </html>

  ---
  style.css
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: #0a0005;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    overflow: hidden;
  }

  canvas {
    display: block;
  }

  ---
  script.js
  const canvas = document.getElementById('heart');
  const ctx = canvas.getContext('2d');

  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;

  const cx = canvas.width / 2;
  const cy = canvas.height / 2;

  const particles = [];
  const TOTAL = 800;

  function heartX(t) {
    return 16 * Math.pow(Math.sin(t), 3);
  }
  function heartY(t) {
    return -(13 * Math.cos(t) - 5 * Math.cos(2 * t) - 2 * Math.cos(3 * t) -
  Math.cos(4 * t));
  }

  for (let i = 0; i < TOTAL; i++) {
    const t = Math.random() * 2 * Math.PI;
    const scale = 12 + Math.random() * 2;
    particles.push({
      ox: heartX(t) * scale,
      oy: heartY(t) * scale,
      x: (Math.random() - 0.5) * canvas.width,
      y: (Math.random() - 0.5) * canvas.height,
      size: Math.random() * 2.5 + 1,
      color: `hsl(${340 + Math.random() * 30}, 100%, ${60 + Math.random() *
  20}%)`,
      speed: 0.015 + Math.random() * 0.02,
      progress: Math.random(),
    });
  }

  let pulse = 0;

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    pulse += 0.04;
    const beat = 1 + Math.sin(pulse) * 0.05;

    for (const p of particles) {
      p.progress = Math.min(p.progress + p.speed, 1);
      const ease = 1 - Math.pow(1 - p.progress, 3);
      p.x += (p.ox * beat - p.x) * ease * p.speed * 5;
      p.y += (p.oy * beat - p.y) * ease * p.speed * 5;

      ctx.beginPath();
      ctx.arc(cx + p.x, cy + p.y, p.size * beat, 0, Math.PI * 2);
      ctx.fillStyle = p.color;
      ctx.shadowBlur = 6;
      ctx.shadowColor = p.color;
      ctx.fill();
    }

    // texto "luxi" en el centro
    ctx.shadowBlur = 20;
    ctx.shadowColor = '#ff69b4';
    ctx.fillStyle = '#fff';
    ctx.font = `bold ${Math.round(52 * beat)}px Georgia, serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('luxi', cx, cy);

    requestAnimationFrame(animate);
  }

  animate();

  window.addEventListener('resize', () => {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  });
